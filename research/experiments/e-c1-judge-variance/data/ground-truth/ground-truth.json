  "criteria": [
    {"id": "check_balance_sheet", "name": "Balance sheet balances", "type": "syntactic", "category": "structural_integrity"},
    {"id": "check_cash_flow_reconciles", "name": "Cash flow reconciles to balance sheet", "type": "syntactic", "category": "structural_integrity"},
    {"id": "check_pnl_flows_to_bs", "name": "P&L flows to balance sheet (net income = RE change)", "type": "syntactic", "category": "structural_integrity"},
    {"id": "check_opening_balances", "name": "Opening balances carry forward", "type": "syntactic", "category": "structural_integrity"},
    {"id": "check_no_hardcoded", "name": "No hardcoded numbers in calculation cells", "type": "syntactic", "category": "formula_integrity"},
    {"id": "check_growth_from_assumptions", "name": "Growth rates derive from assumptions", "type": "syntactic", "category": "formula_integrity"},
    {"id": "check_unit_economics_consistent", "name": "Unit economics are consistent", "type": "syntactic", "category": "formula_integrity"},
    {"id": "check_no_circular_refs", "name": "No circular references", "type": "syntactic", "category": "formula_integrity"},
    {"id": "check_three_statements", "name": "All three statements present", "type": "syntactic", "category": "completeness"},
    {"id": "check_assumptions_page", "name": "Assumptions page/section exists", "type": "syntactic", "category": "completeness"},
    {"id": "check_time_granularity", "name": "Time granularity consistent", "type": "syntactic", "category": "completeness"},
    {"id": "check_full_horizon", "name": "Full time horizon covered (3 years)", "type": "syntactic", "category": "completeness"},
    {"id": "check_no_negative_revenue", "name": "No negative revenue", "type": "syntactic", "category": "sanity"},
    {"id": "check_cash_not_negative", "name": "Cash doesn't go deeply negative without funding", "type": "syntactic", "category": "sanity"},
    {"id": "check_margins_plausible", "name": "Margins within plausible range", "type": "numeric", "category": "sanity"},
    {"id": "check_headcount_math", "name": "Headcount math works", "type": "numeric", "category": "sanity"},
    {"id": "check_tax_rate", "name": "Tax rate applied or labeled pre-tax", "type": "syntactic", "category": "sanity"},
    {"id": "check_periods_labeled", "name": "Periods are labeled", "type": "syntactic", "category": "formatting"},
    {"id": "check_units_specified", "name": "Units are specified", "type": "syntactic", "category": "formatting"},
    {"id": "check_inputs_vs_outputs", "name": "Inputs vs outputs distinguished", "type": "syntactic", "category": "formatting"},
    {"id": "rubric_assumption_quality", "name": "Assumption Quality (1-5)", "type": "semantic", "category": "rubric"},
    {"id": "rubric_scenario_robustness", "name": "Scenario Robustness (1-5)", "type": "semantic", "category": "rubric"},
    {"id": "rubric_operational_realism", "name": "Operational Realism (1-5)", "type": "semantic", "category": "rubric"},
    {"id": "rubric_cash_flow_awareness", "name": "Cash Flow Awareness (1-5)", "type": "semantic", "category": "rubric"},
    {"id": "rubric_decision_utility", "name": "Decision Utility (1-5)", "type": "semantic", "category": "rubric"}
  ],
